{
  "aws": {
    "probe_paths": [
      "http://169.254.169.254/latest/meta-data/",
      "http://169.254.169.254/latest/meta-data/iam/security-credentials/",
      "http://169.254.169.254/latest/meta-data/instance-id",
      "http://[fd00:ec2::254]/latest/meta-data/"
    ],
    "imdsv2_token_path": "http://169.254.169.254/latest/api/token",
    "imdsv2_header": "X-aws-ec2-metadata-token",
    "required_header": {},
    "schema_markers": ["ami-id","instance-id","local-ipv4","hostname","iam","security-credentials","placement","region"]
  },
  "gcp": {
    "probe_paths": [
      "http://metadata.google.internal/computeMetadata/v1/",
      "http://169.254.169.254/computeMetadata/v1/",
      "http://metadata.google.internal/computeMetadata/v1/instance/"
    ],
    "required_header": {"Metadata-Flavor": "Google"},
    "schema_markers": ["project-id","zone","service-accounts","instance","network-interfaces","attributes","id","name"]
  },
  "azure": {
    "probe_paths": [
      "http://169.254.169.254/metadata/instance?api-version=2021-02-01",
      "http://169.254.169.254/metadata/instance/network?api-version=2021-02-01"
    ],
    "required_header": {"Metadata": "true"},
    "schema_markers": ["subscriptionId","resourceGroupName","vmId","location","privateIpAddress","osType","name"]
  },
  "digitalocean": {
    "probe_paths": [
      "http://169.254.169.254/metadata/v1.json",
      "http://169.254.169.254/metadata/v1/"
    ],
    "required_header": {},
    "schema_markers": ["droplet_id","hostname","region","interfaces","floating_ip","dns"]
  },
  "oracle": {
    "probe_paths": [
      "http://169.254.169.254/opc/v1/instance/",
      "http://169.254.169.254/opc/v2/instance/"
    ],
    "required_header": {},
    "schema_markers": ["compartmentId","displayName","region","shape","canonicalRegionName","lifecycleState"]
  },
  "alibaba": {
    "probe_paths": [
      "http://100.100.100.200/latest/meta-data/",
      "http://100.100.100.200/latest/meta-data/instance-id"
    ],
    "required_header": {},
    "schema_markers": ["instance-id","region-id","zone-id","hostname","private-ipv4","image-id"]
  },
  "kubernetes": {
    "probe_paths": [
      "https://kubernetes.default.svc/api/v1/",
      "https://kubernetes.default.svc/version",
      "https://10.96.0.1/api/v1/",
      "https://172.20.0.1/api/v1/"
    ],
    "required_header": {},
    "schema_markers": ["apiVersion","kind","namespaces","pods","services","gitVersion","major","serverAddressByClientCIDRs"]
  },
  "ecs_task": {
    "probe_paths": [
      "http://169.254.170.2/v2/metadata",
      "http://169.254.170.2/v2/stats",
      "http://169.254.170.2/v3/"
    ],
    "required_header": {},
    "schema_markers": ["Cluster","TaskARN","Family","Containers","TaskDefinitionArn","AWS_REGION"]
  }
}
